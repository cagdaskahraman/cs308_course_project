# PostgreSQL — copy to `.env` and adjust for your environment
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=postgres
JWT_SECRET=change_me_to_a_long_random_secret
AUTO_SEED_USERS=true
DEMO_ADMIN_EMAIL=admin@electrostore.local
DEMO_ADMIN_PASSWORD=Admin123!
DEMO_PRODUCT_MANAGER_EMAIL=pm@electrostore.local
DEMO_PRODUCT_MANAGER_PASSWORD=Manager123!
DEMO_SALES_MANAGER_EMAIL=sm@electrostore.local
DEMO_SALES_MANAGER_PASSWORD=Sales123!
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Gmail uses App Password for SMTP_PASS (not account password).
SMTP_FROM=
SMTP_REJECT_UNAUTHORIZED=false
